PORT=3000
RELOAD_INTERVAL=10
SERVER_URL=http://localhost:3000
ENVIRONMENT=development

# Production frontend URL(s), comma-separated in production.
# Example: https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MONGODB_PROD_URL=<your-mongodb-atlas-connection-string>
MONGODB_DEV_URL=mongodb://127.0.0.1:27017/quickRide
JWT_SECRET=<your-json-secret-string>

# Optional Supabase email verification mode.
# If SUPABASE_URL and SUPABASE_ANON_KEY are set, /mail/verify-*-email sends OTP via Supabase.
# /user/verify-email and /captain/verify-email accept { email, otp } in this mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=
EMAIL_VERIFICATION_PROVIDER=supabase

# Optional login enforcement:
# true -> blocks login until emailVerified is true
# false -> allows login even if not verified
REQUIRE_EMAIL_VERIFICATION=false

# Stripe Checkout secret key from dashboard
STRIPE_SECRET_KEY=
